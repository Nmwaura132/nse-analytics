# NSE Analytics - Environment Variables
# Copy this file to .env and fill in your values
# Generate SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# ── Django Core ────────────────────────────────────────────────────────────
# REQUIRED — must be set or the app refuses to start
SECRET_KEY=your_django_secret_key_min_50_chars_generate_with_command_above
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com
FORCE_HTTPS=true

# ── Database (PostgreSQL in production) ───────────────────────────────────
POSTGRES_DB=nse_db
POSTGRES_USER=nse_user
POSTGRES_PASSWORD=your_strong_postgres_password
DB_ENGINE=django.db.backends.postgresql
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nse_db
DB_USER=nse_user
DB_PASSWORD=your_strong_postgres_password

# ── Telegram ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Telegram ID of the admin who receives signup/payment notifications
ADMIN_TELEGRAM_ID=your_telegram_id_here
# Comma-separated Telegram IDs with unlimited AI quota
SUPERUSER_TELEGRAM_IDS=your_telegram_id_here

# ── Security Secrets (generate with: openssl rand -hex 32) ────────────────
# Shared secret passed as X-Bot-Secret header by bots calling /auth/telegram-login
TELEGRAM_BOT_SECRET=generate_with_openssl_rand_hex_32
# Shared secret passed as X-Webhook-Secret by internal services calling /admin/notify
WEBHOOK_SECRET=generate_with_openssl_rand_hex_32

# ── M-Pesa / Daraja ───────────────────────────────────────────────────────
DARAJA_CONSUMER_KEY=your_daraja_consumer_key
DARAJA_CONSUMER_SECRET=your_daraja_consumer_secret
DARAJA_PASSKEY=your_daraja_passkey
DARAJA_SHORTCODE=your_business_shortcode
DARAJA_CALLBACK_URL=https://yourdomain.com/api/subscribe/callback
DARAJA_TOPUP_CALLBACK_URL=https://yourdomain.com/api/topup/callback
DARAJA_ENV=production

# ── Data Sources ───────────────────────────────────────────────────────────
RAPIDAPI_KEY=your_rapidapi_key_here

# ── AI Integrations ────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key
OPENCLAW_API_URL=http://openclaw-gateway:18789
OPENCLAW_API_KEY=
OPENCLAW_MODEL=
OPENCLAW_GATEWAY_TOKEN=your_openclaw_gateway_token
