# NSE Analytics - Environment Variables
# Copy this file to .env and fill in your values

# RapidAPI - NSE stock data
RAPIDAPI_KEY=your_rapidapi_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# MySQL Database
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=nse_db
MYSQL_USER=nse_user
MYSQL_PASSWORD=your_db_password

# Django
SECRET_KEY=your_django_secret_key_min_50_chars
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Database (used by both Django and MySQL container)
DB_NAME=nse_portfolio
DB_USER=root
DB_PASSWORD=your_strong_db_password

# ── OpenClaw AI Integration ────────────────────────────────────────────────
# Local gateway URL (default matches `openclaw gateway run --port 18789`)
OPENCLAW_API_URL=http://localhost:18789

# API key — leave empty when running in trust-local (loopback) mode
OPENCLAW_API_KEY=

# Model override — leave empty to use the gateway's configured default
# Example: gpt-4o, claude-3-5-sonnet, gemini-2.5-pro
OPENCLAW_MODEL=
